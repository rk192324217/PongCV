# Copy this file to .env and fill in real values
# Never commit .env to git

# MongoDB - get this from MongoDB Atlas dashboard
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/visionpong

# JWT - make these long random strings (run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Server port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
